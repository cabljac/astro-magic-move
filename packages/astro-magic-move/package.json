{
  "name": "astro-magic-move",
  "version": "0.4.0",
  "description": "Animated code morphing for Astro, powered by Shiki Magic Move. Build-time tokenization, zero-framework client JS, CSS-variable theming.",
  "type": "module",
  "license": "MIT",
  "author": "Jacob Cable",
  "repository": {
    "type": "git",
    "url": "https://github.com/cabljac/astro-magic-move"
  },
  "homepage": "https://astro-magic-move.dev",
  "scripts": {
    "prepublishOnly": "cp ../../README.md README.md",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "exports": {
    ".": "./index.ts",
    "./helpers": "./src/helpers.ts",
    "./styles": "./styles/magic-move.css"
  },
  "files": [
    "README.md",
    "index.ts",
    "src/",
    "!src/**/*.test.ts",
    "!src/**/*.spec.ts",
    "styles/",
    "LICENSE"
  ],
  "keywords": [
    "astro-component",
    "withastro",
    "shiki",
    "code-animation",
    "magic-move"
  ],
  "peerDependencies": {
    "astro": "^5.0.0 || ^6.0.0"
  },
  "dependencies": {
    "shiki": "^3.0.0",
    "shiki-magic-move": "^1.3.0"
  },
  "devDependencies": {
    "vitest": "^4.1.4"
  }
}
