---
import { createHighlighter, type HighlighterGeneric } from "shiki";
import { codeToKeyedTokens, createMagicMoveMachine } from "shiki-magic-move/core";
import { cssVarTheme } from "./theme";
import type { MagicMoveProps } from "./types";

interface Props extends MagicMoveProps {}

const {
	before,
	after,
	steps: stepsProp,
	lang = "typescript",
	trigger = "scroll",
	duration = 800,
	stagger = 0.3,
	threshold = 0.4,
	lineNumbers = false,
	minLines,
	class: className,
} = Astro.props;

// Resolve steps from props
let steps: string[];
if (stepsProp) {
	if (stepsProp.length < 2) {
		throw new Error("[astro-magic-move] `steps` must contain at least 2 items.");
	}
	steps = stepsProp;
} else if (before != null && after != null) {
	steps = [before, after];
} else {
	throw new Error("[astro-magic-move] Provide either `before` + `after` or `steps` (min 2 items).");
}

// Module-level highlighter cache (survives HMR via globalThis)
const CACHE_KEY = "__astro_magic_move_hl";
type HLCache = Map<string, HighlighterGeneric<string, string>>;
const hlCache: HLCache = ((globalThis as Record<string, unknown>)[CACHE_KEY] ??=
	new Map()) as HLCache;

let highlighter = hlCache.get(lang);
if (!highlighter) {
	highlighter = await createHighlighter({
		themes: [cssVarTheme],
		langs: [lang],
	});
	hlCache.set(lang, highlighter);
}

// Build the magic move machine and compile all steps at build time
const machine = createMagicMoveMachine(
	(code) => codeToKeyedTokens(highlighter, code, { lang, theme: "css-variables" }, lineNumbers),
	{},
);

const compiledSteps = steps.map((code) => machine.commit(code).current);

const stepsJson = JSON.stringify(compiledSteps);
---

<magic-move
	class:list={["magic-move", className]}
	data-trigger={trigger}
	data-duration={duration}
	data-stagger={stagger}
	data-threshold={threshold}
	data-lang={lang}
	{...(lineNumbers ? { "data-line-numbers": "" } : {})}
	{...(minLines ? { style: `--min-lines: ${minLines}` } : {})}
>
	<pre class="shiki-magic-move-container"><code>{steps[0]}</code></pre>
	<script is:inline type="application/json" set:html={stepsJson} />
</magic-move>

<script>
	import { MagicMoveRenderer } from "shiki-magic-move/renderer";

	// Runtime guard so the class declaration doesn't blow up when the <script>
	// block accidentally ends up in an SSR module graph (a known Astro seam
	// with .astro files inside node_modules and MDX-rendered components).
	// In the browser this is true; in Node/Cloudflare Workers it's false and
	// we skip declaring the custom element entirely — the client bundle reaches
	// the browser as usual and registers the element there.
	if (typeof HTMLElement !== "undefined" && typeof customElements !== "undefined") {
	class MagicMoveElement extends HTMLElement {
		#renderer: MagicMoveRenderer | null = null;
		#steps: any[] = [];
		#currentStep = 0;
		#animating = false;
		#pendingStep: number | null = null;
		#observer: IntersectionObserver | null = null;
		#ready = false;

		get step(): number {
			return this.#currentStep;
		}

		set step(value: number) {
			const idx = Number(value);
			if (Number.isNaN(idx)) return;
			if (!this.#ready) {
				this.#pendingStep = idx;
				return;
			}
			this.#animateToStep(idx);
		}

		get totalSteps(): number {
			return this.#steps.length;
		}

		get isReady(): boolean {
			return this.#ready;
		}

		connectedCallback() {
			const trigger = this.dataset.trigger ?? "scroll";
			const threshold = Number(this.dataset.threshold ?? 0.4);

			if (this.#ready) {
				// Defensive re-entry: if the element is moved out of and back into the
				// DOM, click listeners persist on the element and auto-play is one-shot,
				// but the scroll observer was torn down in disconnectedCallback.
				if (trigger === "scroll" && this.#currentStep === 0 && !this.#observer) {
					this.#setupScrollTrigger(threshold);
				}
				return;
			}

			const dataScript = this.querySelector('script[type="application/json"]');
			if (!dataScript?.textContent) return;
			this.#steps = JSON.parse(dataScript.textContent);
			dataScript.remove();

			const container = this.querySelector("pre");
			if (!container) return;
			container.innerHTML = "";

			const duration = Number(this.dataset.duration ?? 800);
			const stagger = Number(this.dataset.stagger ?? 0.3);
			const lineNumbers = this.hasAttribute("data-line-numbers");

			this.#renderer = new MagicMoveRenderer(container, {
				duration,
				stagger,
				lineNumbers,
				animateContainer: true,
			});

			if (trigger === "auto") {
				this.#currentStep = -1;
			} else {
				this.#renderer.replace(this.#steps[0]);
				this.#currentStep = 0;
			}
			this.#setupTrigger(trigger, threshold);

			this.#ready = true;
			this.dispatchEvent(new CustomEvent("magic-move:ready", { bubbles: true }));

			if (this.#pendingStep !== null) {
				const queued = this.#pendingStep;
				this.#pendingStep = null;
				this.#animateToStep(queued);
			}
		}

		disconnectedCallback() {
			this.#observer?.disconnect();
			this.#observer = null;
		}

		#setupTrigger(trigger: string, threshold: number) {
			switch (trigger) {
				case "scroll":
					this.#setupScrollTrigger(threshold);
					break;
				case "click":
					this.style.cursor = "pointer";
					this.addEventListener("click", () => {
						const next = (this.#currentStep + 1) % this.#steps.length;
						this.#animateToStep(next);
					});
					break;
				case "auto":
					requestAnimationFrame(() => this.#autoPlay());
					break;
				case "none":
					break;
			}
		}

		#setupScrollTrigger(threshold: number) {
			this.#observer = new IntersectionObserver(
				([entry]) => {
					if (entry.isIntersecting) {
						this.#animateToStep(1);
						this.#observer?.disconnect();
						this.#observer = null;
					}
				},
				{ threshold },
			);
			this.#observer.observe(this);
		}

		async #autoPlay() {
			const duration = Number(this.dataset.duration ?? 800);
			for (let i = 0; i < this.#steps.length; i++) {
				await this.#animateToStep(i);
				if (i < this.#steps.length - 1) {
					await new Promise((r) => setTimeout(r, duration + 200));
				}
			}
		}

		async #animateToStep(stepIndex: number) {
			if (!this.#renderer || stepIndex === this.#currentStep) return;
			if (stepIndex < 0 || stepIndex >= this.#steps.length) return;

			if (this.#animating) {
				this.#pendingStep = stepIndex;
				return;
			}

			this.#animating = true;
			try {
				await this.#renderer.render(this.#steps[stepIndex]);
				this.#currentStep = stepIndex;
				this.dispatchEvent(
					new CustomEvent("magic-move:step", {
						detail: { step: stepIndex, total: this.#steps.length },
						bubbles: true,
					}),
				);
			} finally {
				this.#animating = false;
			}

			if (this.#pendingStep !== null) {
				const next = this.#pendingStep;
				this.#pendingStep = null;
				this.#animateToStep(next);
			}
		}
	}

	if (!customElements.get("magic-move")) {
		customElements.define("magic-move", MagicMoveElement);
	}
	}
</script>

<style is:global>
	magic-move {
		display: block;
		position: relative;
	}

	magic-move .shiki-magic-move-container {
		margin: 0;
		overflow-x: auto;
		overflow-y: hidden;
		scrollbar-width: thin;
	}
</style>
