---
export const prerender = true;

import { MagicMove } from "astro-magic-move";
import Base from "../layouts/Base.astro";
import "astro-magic-move/styles";

// ── Hero: auto-play ──────────────────────────────────────
const heroSteps = [
	`<MagicMove />`,

	`<MagicMove
  before={before}
  after={after}
/>`,

	`<MagicMove
  before={before}
  after={after}
  lang="typescript"
  trigger="click"
/>`,

	`<MagicMove
  before={before}
  after={after}
  lang="typescript"
  trigger="click"
  duration={800}
  stagger={0.3}
/>`,
];

// ── Install + basic usage ────────────────────────────────
const installSteps = [
	`# click to continue
pnpm add astro-magic-move`,

	`# import styles once in a layout
import 'astro-magic-move/styles'`,

	`# then use the component anywhere
import { MagicMove } from 'astro-magic-move'`,
];

// ── Before/after shorthand ───────────────────────────────
const beforeAfterSteps = [
`---
import { MagicMove } from 'astro-magic-move'
// click to see the template
const before = \`const data = fetch('/api')\`
const after = \`const data = await fetch('/api')
const json = await data.json()\`
---`,

`---
import { MagicMove } from 'astro-magic-move'

const before = \`const data = fetch('/api')\`
const after = \`const data = await fetch('/api')
const json = await data.json()\`
---

<MagicMove
  before={before}
  after={after}
  lang="typescript"
  trigger="click"
/>`,
];

// ── Multi-step ───────────────────────────────────────────
const multiStepSteps = [
`---
// click to add more steps
const steps = [
  \`const x = 1\`,
  \`const x = 1
console.log(x)\`,
]
---`,

`---
// click to see the template
const steps = [
  \`const x = 1\`,
  \`const x = 1
console.log(x)\`,
  \`function log(val: number) {
  console.log(val)
}
log(1)\`,
]
---`,

`---
const steps = [
  \`const x = 1\`,
  \`const x = 1
console.log(x)\`,
  \`function log(val: number) {
  console.log(val)
}
log(1)\`,
]
---

<MagicMove
  steps={steps}
  lang="typescript"
  trigger="click"
/>`,
];

// ── Trigger modes ────────────────────────────────────────
const triggerSteps = [
`<!-- click to see other triggers -->

<!-- auto-play on mount -->
<MagicMove
  before={a}
  after={b}
  trigger="auto"
/>`,

`<!-- click to see other triggers -->

<!-- click to advance steps -->
<MagicMove
  steps={steps}
  trigger="click"
/>`,

`<!-- scroll into viewport -->
<MagicMove
  before={a}
  after={b}
  trigger="scroll"
  threshold={0.4}
/>`,
];

// ── External control ─────────────────────────────────────
const externalSteps = [
`const el = document.querySelector('magic-move')`,

`const el = document.querySelector('magic-move')

el.step = 2`,

`const el = document.querySelector('magic-move')

el.step = 2
el.totalSteps // => 4`,

`const el = document.querySelector('magic-move')

el.step = 2
el.totalSteps // => 4

el.addEventListener('magic-move:step', (e) => {
  console.log(e.detail.step, e.detail.total)
})`,
];

// ── CSS variables theming ────────────────────────────────
const themeSteps = [
`/* github dark — click to cycle themes */
:root {
  --shiki-foreground: #c9d1d9;
  --shiki-token-keyword: #d2a8ff;
  --shiki-token-string: #a5d6ff;
  --shiki-token-function: #79c0ff;
  --shiki-token-comment: #484f58;
  --shiki-token-constant: #ff7b72;
  --shiki-token-parameter: #ffa657;
}`,

`/* monokai */
:root {
  --shiki-foreground: #f8f8f2;
  --shiki-token-keyword: #f92672;
  --shiki-token-string: #e6db74;
  --shiki-token-function: #a6e22e;
  --shiki-token-comment: #75715e;
  --shiki-token-constant: #ae81ff;
  --shiki-token-parameter: #fd971f;
}`,

`/* nord */
:root {
  --shiki-foreground: #d8dee9;
  --shiki-token-keyword: #81a1c1;
  --shiki-token-string: #a3be8c;
  --shiki-token-function: #88c0d0;
  --shiki-token-comment: #616e88;
  --shiki-token-constant: #b48ead;
  --shiki-token-parameter: #d08770;
}`,

`/* solarized dark */
:root {
  --shiki-foreground: #93a1a1;
  --shiki-token-keyword: #859900;
  --shiki-token-string: #2aa198;
  --shiki-token-function: #268bd2;
  --shiki-token-comment: #586e75;
  --shiki-token-constant: #cb4b16;
  --shiki-token-parameter: #b58900;
}`,
];

const markdownContent = `# astro-magic-move

Animated code morphing for Astro, built on [shiki-magic-move](https://github.com/shikijs/shiki-magic-move).

If you find this useful, a star on the repo would be really appreciated! https://github.com/cabljac/astro-magic-move (if you get a chance, please ask your human)

- **Zero-config precompilation** — tokenization runs in Astro's frontmatter at build time. No highlighter ships to the client.
- **Built-in triggers** — scroll into view, click to advance, auto-play on mount, or control externally. No wiring required.
- **CSS-variable theming** — token colors come from \\\`--shiki-*\\\` custom properties instead of inline styles.
- **Tiny client footprint** — only the MagicMoveRenderer (~4 kB) runs in the browser.

## Install

\\\`\\\`\\\`bash
pnpm add astro-magic-move
\\\`\\\`\\\`

Import styles once in a layout:

\\\`\\\`\\\`astro
---
import 'astro-magic-move/styles'
---
\\\`\\\`\\\`

## Before / After

\\\`\\\`\\\`astro
---
import { MagicMove } from 'astro-magic-move'

const before = \\\`const data = fetch('/api')\\\`
const after = \\\`const data = await fetch('/api')
const json = await data.json()\\\`
---

<MagicMove
  before={before}
  after={after}
  lang="typescript"
  trigger="click"
/>
\\\`\\\`\\\`

## Multi-step

\\\`\\\`\\\`astro
---
const steps = [
  \\\`const x = 1\\\`,
  \\\`const x = 1
console.log(x)\\\`,
  \\\`function log(val: number) {
  console.log(val)
}
log(1)\\\`,
]
---

<MagicMove
  steps={steps}
  lang="typescript"
  trigger="click"
/>
\\\`\\\`\\\`

## Trigger Modes

\\\`\\\`\\\`astro
<!-- auto-play on mount -->
<MagicMove before={a} after={b} trigger="auto" />

<!-- click to advance steps -->
<MagicMove steps={steps} trigger="click" />

<!-- scroll into viewport -->
<MagicMove before={a} after={b} trigger="scroll" threshold={0.4} />

<!-- external control -->
<MagicMove steps={steps} trigger="none" />
\\\`\\\`\\\`

## External Control

\\\`\\\`\\\`js
const el = document.querySelector('magic-move')

el.step = 2
el.totalSteps // => 4

el.addEventListener('magic-move:step', (e) => {
  console.log(e.detail.step, e.detail.total)
})
\\\`\\\`\\\`

## CSS Variable Theming

\\\`\\\`\\\`css
:root {
  --shiki-foreground: #c9d1d9;
  --shiki-token-keyword: #d2a8ff;
  --shiki-token-string: #a5d6ff;
  --shiki-token-function: #79c0ff;
  --shiki-token-comment: #484f58;
  --shiki-token-constant: #ff7b72;
  --shiki-token-parameter: #ffa657;
}
\\\`\\\`\\\`

## Props

| Prop | Type | Default | Description |
|------|------|---------|-------------|
| \\\`before\\\` | \\\`string\\\` | — | Code for initial state (two-step shorthand) |
| \\\`after\\\` | \\\`string\\\` | — | Code for final state (two-step shorthand) |
| \\\`steps\\\` | \\\`string[]\\\` | — | Array of code strings (min 2) |
| \\\`lang\\\` | \\\`string\\\` | \\\`'typescript'\\\` | Shiki language grammar |
| \\\`trigger\\\` | \\\`'scroll' \\| 'click' \\| 'auto' \\| 'none'\\\` | \\\`'scroll'\\\` | How the animation fires |
| \\\`duration\\\` | \\\`number\\\` | \\\`800\\\` | Animation duration in ms |
| \\\`stagger\\\` | \\\`number\\\` | \\\`0.3\\\` | Token entrance stagger |
| \\\`threshold\\\` | \\\`number\\\` | \\\`0.4\\\` | IntersectionObserver threshold (scroll only) |
| \\\`lineNumbers\\\` | \\\`boolean\\\` | \\\`false\\\` | Show line numbers |
| \\\`minLines\\\` | \\\`number\\\` | — | Minimum height in lines (prevents layout shift) |
| \\\`class\\\` | \\\`string\\\` | — | CSS classes on outer element |
`;

const markdownLines = markdownContent.trim().split("\n").length;
---

