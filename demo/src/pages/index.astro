					<svg id="icon-sun" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
					<svg id="icon-moon" class="w-3.5 h-3.5 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
					<span id="toggle-label">try light mode</span>
				</button>
			</div>
			<div class="bg-[var(--site-surface)] border border-[var(--site-border)] rounded-lg sm:rounded-[10px] overflow-hidden text-left transition-colors duration-400">
				<div class="flex items-center gap-3 px-3.5 py-2.5 border-b border-[var(--site-border-subtle)]">
					<div class="flex gap-1.5">
						<span class="w-2 h-2 rounded-full bg-[var(--site-dot)]"></span>
						<span class="w-2 h-2 rounded-full bg-[var(--site-dot)]"></span>
						<span class="w-2 h-2 rounded-full bg-[var(--site-dot)]"></span>
					</div>
					<span class="font-mono text-[0.6875rem] text-[var(--site-text-dim)]">global.css</span>
				</div>
				<MagicMove steps={themeSteps} lang="css" trigger="click" />
			</div>
		</section>
	</main>

	<script is:inline>
		customElements.whenDefined("magic-move").then(() => {
			const el = document.querySelector("#ext-demo magic-move");
			const prev = document.getElementById("ext-prev");
			const next = document.getElementById("ext-next");
			const counter = document.getElementById("ext-counter");

			function update() {
				counter.textContent = `${el.step + 1}/${el.totalSteps}`;
				prev.disabled = el.step === 0;
				next.disabled = el.step === el.totalSteps - 1;
			}

			function start() {
				update();
				prev.addEventListener("click", () => { el.step = el.step - 1; });
				next.addEventListener("click", () => { el.step = el.step + 1; });
				el.addEventListener("magic-move:step", update);
			}

			if (el.isReady) start();
			else el.addEventListener("magic-move:ready", start, { once: true });
		});
	</script>

	<script is:inline define:vars={{ markdownContent }}>
		const defaultLabel = document.querySelector("#copy-md span")?.textContent;
		document.getElementById("copy-md")?.addEventListener("click", async (e) => {
			const span = e.currentTarget.querySelector("span");
			try {
				await navigator.clipboard.writeText(markdownContent);
				span.textContent = "copied!";
				setTimeout(() => { span.textContent = defaultLabel; }, 2000);
			} catch {
				span.textContent = "failed";
				setTimeout(() => { span.textContent = defaultLabel; }, 2000);
			}
		});
	</script>

	<script is:inline>
		{
			const html = document.documentElement;
			const root = document.documentElement.style;
			const toggle = document.getElementById("theme-toggle");
			const toggleLabel = document.getElementById("toggle-label");
			const iconSun = document.getElementById("icon-sun");
			const iconMoon = document.getElementById("icon-moon");
			const themingSection = document.getElementById("theming-section");

			const shikiThemes = [
				{ "--shiki-foreground": "#c9d1d9", "--shiki-token-keyword": "#d2a8ff", "--shiki-token-string": "#a5d6ff", "--shiki-token-function": "#79c0ff", "--shiki-token-comment": "#484f58", "--shiki-token-constant": "#ff7b72", "--shiki-token-parameter": "#ffa657" },
				{ "--shiki-foreground": "#f8f8f2", "--shiki-token-keyword": "#f92672", "--shiki-token-string": "#e6db74", "--shiki-token-function": "#a6e22e", "--shiki-token-comment": "#75715e", "--shiki-token-constant": "#ae81ff", "--shiki-token-parameter": "#fd971f" },
				{ "--shiki-foreground": "#d8dee9", "--shiki-token-keyword": "#81a1c1", "--shiki-token-string": "#a3be8c", "--shiki-token-function": "#88c0d0", "--shiki-token-comment": "#616e88", "--shiki-token-constant": "#b48ead", "--shiki-token-parameter": "#d08770" },
				{ "--shiki-foreground": "#93a1a1", "--shiki-token-keyword": "#859900", "--shiki-token-string": "#2aa198", "--shiki-token-function": "#268bd2", "--shiki-token-comment": "#586e75", "--shiki-token-constant": "#cb4b16", "--shiki-token-parameter": "#b58900" },
			];

			const shikiVars = Object.keys(shikiThemes[0]);

			function applyShiki(theme) {
				shikiVars.forEach((v) => root.setProperty(v, theme[v]));
			}

			function clearShiki() {
				shikiVars.forEach((v) => root.removeProperty(v));
			}

			function setLight(light) {
				html.classList.toggle("light", light);
				if (toggleLabel) toggleLabel.textContent = light ? "try dark mode" : "try light mode";
				if (iconSun) iconSun.classList.toggle("hidden", light);
				if (iconMoon) iconMoon.classList.toggle("hidden", !light);
			}

			toggle?.addEventListener("click", () => {
				setLight(!html.classList.contains("light"));
				clearShiki();
			});

			const themeMM = themingSection?.querySelector("magic-move");
			themeMM?.addEventListener("magic-move:step", (e) => {
				applyShiki(shikiThemes[e.detail.step]);
			});
		}
	</script>

	<footer class="text-center px-4 sm:px-8 py-10 sm:py-12 border-t border-[var(--site-border-subtle)]">
		<p class="text-xs text-[var(--site-text-dim)]">
			Built with
			<a href="https://github.com/shikijs/shiki-magic-move" target="_blank" rel="noopener" class="text-[var(--site-text-muted)] no-underline border-b border-[var(--site-border)] transition-colors hover:text-[var(--site-text)]">
				shiki-magic-move
			</a>
		</p>
	</footer>
</Base>
